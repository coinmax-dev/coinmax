# ═══════════════════════════════════════════════════════════════
#  CoinMax V3 Deployment Configuration
# ═══════════════════════════════════════════════════════════════

# ─── Deployer ────────────────────────────────────────────────
# Private key of the deployer wallet (needs native tokens on each chain)
DEPLOYER_PRIVATE_KEY=0x...

# ─── thirdweb Engine Server Wallet ───────────────────────────
# The Server Wallet address from thirdweb Engine dashboard
# Used for: daily interest processing, cross-chain relay, price updates
SERVER_WALLET_ADDRESS=0x...

# ─── RPC URLs (optional, defaults provided) ──────────────────
# BSC_RPC_URL=https://bsc-dataseed1.binance.org
# ARB_RPC_URL=https://arb1.arbitrum.io/rpc
# BASE_RPC_URL=https://mainnet.base.org
# ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# ─── Pre-deployed Contracts ──────────────────────────────────
# MA Token (deploy via thirdweb dashboard first → Token Drop on ARB)
MA_TOKEN_ADDRESS=0x...

# ─── Chain-specific Token Addresses ──────────────────────────
# ARB
ARB_USDT=0xFd086bC7CD5C481DCC9C85ebE478A1C0b69FCbb9
ARB_USDC=0xaf88d065e77c8cC2239327C5EDb3A432268e5831

# BSC
BSC_USDT=0x55d398326f99059fF775485246999027B3197955
BSC_USDC=0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d

# Base
BASE_USDT=0xfde4C96c8593536E31F229EA8f37b2ADa2699bb2
BASE_USDC=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ─── DEX Routers ─────────────────────────────────────────────
ARB_DEX_ROUTER=0xE592427A0AEce92De3Edee1F18E0157C05861564
ARB_POOL_FEE=500
BSC_DEX_ROUTER=0x13f4EA83D0bd40E75C8222255bc855a974568Dd4
BSC_POOL_FEE=100
BASE_DEX_ROUTER=0x2626664c2603336E57B271c5C0b26F421741e481
BASE_POOL_FEE=100

# ─── Treasury Wallets (per chain — receives USDC) ────────────
ARB_TREASURY=0x...
BSC_TREASURY=0x...
BASE_TREASURY=0x...

# ─── MA Price ────────────────────────────────────────────────
# 6 decimals: 100000 = $0.10, 1000000 = $1.00
MA_PRICE=100000

